      "rollup@>=4.0.0 <4.22.4": ">=4.22.4",
      "hono@<4.6.5": ">=4.6.5"
    },
    "patchedDependencies": {}
  },
  "size-limit": [
    {
      "name": "import * from 'ox'",
      "path": "./dist/index.js",
      "import": "*"
    },
    {
      "name": "import { Hex } from 'ox'; console.log(Hex.assert)",
      "path": "./dist/index.js",
      "import": "{ Hex.assert }"
    }
  ],
